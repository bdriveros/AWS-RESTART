   "source": [
    "s3=boto3.client('s3')\n",
    "\n",
    "def upload_file(file_name,bucket):\n",
    "    s3.upload_file(file_name,bucket,file_name)\n",
    "    print(f'{file_name} has been uploaded to {bucket}')\n",
    "\n",
    "upload_file('test.txt','s3aws-restart1111')"
   ]
  }
